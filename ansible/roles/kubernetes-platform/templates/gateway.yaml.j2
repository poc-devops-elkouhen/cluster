apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: {{ traefik_gateway_name }}
  namespace: {{ traefik_gateway_namespace }}
spec:
  gatewayClassName: traefik
  listeners:
    - name: web
      port: {{ traefik_gateway_listener_port }}
      protocol: HTTP
      allowedRoutes:
        namespaces:
          from: All
    - name: websecure
      port: {{ traefik_gateway_tls_listener_port }}
      protocol: HTTPS
      tls:
        mode: Terminate
        certificateRefs:
          - group: ""
            kind: Secret
            name: {{ traefik_gateway_tls_secret_name }}
      allowedRoutes:
        namespaces:
          from: All
